# =============================================================================
# Clawback Production Environment Variables
# Copy to .env and fill in all required values before running docker compose up
# =============================================================================

# -- Postgres --
POSTGRES_DB=clawback
POSTGRES_USER=clawback
POSTGRES_PASSWORD=         # REQUIRED: strong random password
POSTGRES_PORT=5432

# -- MinIO (S3-compatible object storage) --
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=       # REQUIRED: strong random password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -- OpenClaw Runtime --
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_TOKEN=    # REQUIRED: random token for gateway auth
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# At least one model provider credential is required for runtime-backed answers.
OPENAI_API_KEY=            # Recommended default for 0.4
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# OLLAMA_API_KEY=

# -- Control Plane (core API) --
CONTROL_PLANE_PORT=3001
COOKIE_SECRET=             # REQUIRED: 32+ char random string for session signing
CLAWBACK_RUNTIME_API_TOKEN=  # REQUIRED: random token for worker-to-API auth
CLAWBACK_APPROVAL_SURFACE_SECRET=  # REQUIRED: random string for approval surface tokens

# -- Console (Next.js frontend) --
CONSOLE_PORT=3000
CONSOLE_ORIGIN=https://clawback.example.com  # MUST match CLAWBACK_DOMAIN with https://
CONTROL_PLANE_INTERNAL_URL=http://control-plane:3001  # Console -> control-plane proxy target inside Docker

# -- TLS Reverse Proxy (Caddy) --
CLAWBACK_DOMAIN=clawback.example.com   # REQUIRED: public hostname — DNS A record must point to this host

# -- Optional: Inbound Email (Postmark webhook) --
# CLAWBACK_INBOUND_EMAIL_WEBHOOK_TOKEN=  # Token to validate Postmark webhook calls when this surface is enabled

# -- Optional: Gmail Integration --
# CLAWBACK_GMAIL_WATCH_HOOK_TOKEN=       # Token for Gmail push notification webhook when this surface is enabled
# CLAWBACK_GMAIL_POLLING_ENABLED=true    # Enable/disable Gmail polling (default: true)
# CLAWBACK_GMAIL_POLL_INTERVAL_MS=60000  # Poll interval in ms (default: 60000)

# -- Optional: SMTP (for sending reviewed emails) --
# CLAWBACK_SMTP_HOST=smtp.example.com
# CLAWBACK_SMTP_PORT=587
# CLAWBACK_SMTP_FROM_ADDRESS=noreply@example.com
# CLAWBACK_SMTP_FROM_NAME=Clawback
# CLAWBACK_SMTP_USERNAME=
# CLAWBACK_SMTP_PASSWORD=
# CLAWBACK_SMTP_REPLY_TO=
# CLAWBACK_SMTP_SECURE=false

# -- Optional: Slack Integration --
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# -- Optional: WhatsApp Integration --
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_VERIFY_TOKEN=    # Required only when enabling the WhatsApp webhook surface
# WHATSAPP_APP_SECRET=
