{
  "name": "clawback",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.29.3"
  },
  "scripts": {
    "build": "pnpm run build:packages && pnpm run build:services && pnpm --filter @clawback/console build",
    "build:packages": "pnpm --filter @clawback/contracts --filter @clawback/domain --filter @clawback/db --filter @clawback/policy --filter @clawback/auth --filter @clawback/model-adapters --filter @clawback/retrieval --filter @clawback/plugin-sdk --filter @clawback/plugin-manifests build",
    "build:services": "pnpm --filter @clawback/control-plane --filter @clawback/runtime-worker build",
    "typecheck": "pnpm run build:packages && pnpm run typecheck:packages && pnpm run typecheck:services && pnpm --filter @clawback/console typecheck",
    "typecheck:packages": "pnpm --filter @clawback/contracts --filter @clawback/domain --filter @clawback/db --filter @clawback/policy --filter @clawback/auth --filter @clawback/model-adapters --filter @clawback/retrieval --filter @clawback/plugin-sdk --filter @clawback/plugin-manifests typecheck",
    "typecheck:services": "pnpm --filter @clawback/control-plane --filter @clawback/runtime-worker typecheck",
    "lint": "pnpm run build:packages && pnpm run lint:packages && pnpm run lint:services && pnpm --filter @clawback/console lint",
    "lint:packages": "pnpm --filter @clawback/contracts --filter @clawback/domain --filter @clawback/db --filter @clawback/policy --filter @clawback/auth --filter @clawback/model-adapters --filter @clawback/retrieval --filter @clawback/plugin-sdk --filter @clawback/plugin-manifests lint",
    "lint:services": "pnpm --filter @clawback/control-plane --filter @clawback/runtime-worker lint",
    "test": "pnpm run build:packages && pnpm run test:packages && pnpm run test:services",
    "test:packages": "pnpm --filter @clawback/contracts --filter @clawback/domain --filter @clawback/db --filter @clawback/policy --filter @clawback/auth --filter @clawback/model-adapters --filter @clawback/retrieval --filter @clawback/plugin-sdk --filter @clawback/plugin-manifests test",
    "test:services": "pnpm --filter @clawback/control-plane --filter @clawback/runtime-worker test",
    "test:env": "pnpm --filter @clawback/env test",
    "test:console": "pnpm --filter @clawback/console test",
    "test:console:e2e": "playwright test -c apps/console/playwright.config.ts",
    "test:console:first-run:e2e": "playwright test -c apps/console/playwright.config.ts apps/console/e2e/first-run-acceptance.e2e.ts",
    "test:deployed-stack": "./scripts/test-deployed-stack.sh",
    "test:migration-proof": "./scripts/test-migration-proof.sh",
    "dev": "pnpm --parallel --filter @clawback/console --filter @clawback/control-plane --filter @clawback/runtime-worker dev",
    "openclaw:dev": "./scripts/run-host-openclaw.sh",
    "openclaw:stop": "./scripts/run-host-openclaw.sh --stop",
    "compose:env": "node infra/scripts/prepare-local-compose.mjs",
    "compose:up:core": "pnpm compose:env && docker compose -f infra/compose/docker-compose.yml --env-file infra/compose/.env up -d --wait postgres minio",
    "compose:down:core": "pnpm compose:env && docker compose -f infra/compose/docker-compose.yml --env-file infra/compose/.env down -v postgres minio",
    "compose:up": "pnpm compose:env && docker compose -f infra/compose/docker-compose.yml --env-file infra/compose/.env up -d --wait",
    "compose:down": "pnpm compose:env && docker compose -f infra/compose/docker-compose.yml --env-file infra/compose/.env down -v",
    "compose:config": "pnpm compose:env && docker compose -f infra/compose/docker-compose.yml --env-file infra/compose/.env config",
    "smoke:connector-sync": "node infra/scripts/run-connector-sync-smoke.mjs",
    "smoke:public-try": "./scripts/public-try-verify.sh",
    "smoke:incident-copilot": "node infra/scripts/run-incident-copilot-smoke.mjs",
    "smoke:incident-copilot-action": "node infra/scripts/run-incident-copilot-governed-action-smoke.mjs",
    "db:generate": "pnpm --filter @clawback/db db:generate",
    "db:migrate": "pnpm --filter @clawback/db db:migrate",
    "db:seed": "pnpm --filter @clawback/db db:seed",
    "spike:w0": "node infra/scripts/run-openclaw-w0-spike.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.4.0",
    "@types/ws": "^8.18.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
